NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Audit email (Resend)
RESEND_API_KEY=re_your_key_here
# Set to "false" to disable all audit emails (useful in dev)
AUDIT_EMAIL_ENABLED=true

# Player-facing transactional email. Sent on registration, prediction submit/update,
# and when knockouts open. Must be an address on a verified Resend domain — otherwise
# delivery to anyone other than the Resend account owner will fail.
# Domain currently verified: beta.footballpredictiongame.com (eu-west-1).
PLAYER_EMAIL_FROM="Freemo's Prediction Game <freemos@beta.footballpredictiongame.com>"

# Public site URL. Used to build absolute links in outbound mail (e.g. unsubscribe).
# In prod set to the canonical https URL; in dev http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chat audit webhook — called by Supabase trigger after chat_messages insert.
# Must exactly match the value set on the Postgres side via:
#   ALTER DATABASE postgres SET app.chat_audit_secret = '<same-value>';
CHAT_AUDIT_WEBHOOK_SECRET=generate-a-random-32-byte-hex-and-put-same-value-in-db-guc
